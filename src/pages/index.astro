---
import { getCollection } from 'astro:content';
import DiaryLayout from '../layouts/DiaryLayout.astro';
import aesthetics from '../content/settings/aesthetics.json';

// Fetch all diario entries and sort by date descending
const diarioEntries = (await getCollection('diario')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const authorName = aesthetics.authorName || "ISARP5";
const siteDescription = aesthetics.siteDescription || "Mi diario personal";
---

<DiaryLayout>
	<header class="home-header">
		<h1>{aesthetics.siteTitle || "FLOU"}</h1>
		<p class="description">{siteDescription}</p>
		<p class="author">Por: <strong>{authorName}</strong></p>
	</header>
	<hr />
	<main>
		<h2 class="section-title">Entradas del Diario</h2>
		{diarioEntries.length === 0 ? (
			<p>Aún no hay entradas en el diario.</p>
		) : (
			<ul class="entries-list">
				{diarioEntries.map((entry) => (
					<li>
						<div class="entry-item">
							<time datetime={entry.data.date.toISOString()}>
								{entry.data.date.toLocaleDateString('es-ES', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
							<a href={`/FLOU/diario/${entry.id}/`}>{entry.data.title}</a>
							{entry.data.tags && entry.data.tags.length > 0 && (
								<span class="tags">
									{entry.data.tags.map((tag) => (
										<span class="tag">#{tag}</span>
									))}
								</span>
							)}
						</div>
					</li>
				))}
			</ul>
		)}
	</main>
</DiaryLayout>

<style>
	.home-header {
		margin-bottom: 2rem;
	}

	.description {
		opacity: 0.8;
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.author {
		opacity: 0.6;
		font-size: 0.9rem;
		margin: 0;
	}

	.section-title {
		font-size: 1.4rem;
		margin-bottom: 1.5rem;
	}

	.entries-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.entries-list li {
		margin-bottom: 1.5rem;
	}

	.entry-item {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.entry-item time {
		font-size: 0.85rem;
		opacity: 0.5;
	}

	.entry-item a {
		font-size: 1.2rem;
		font-weight: 600;
		text-decoration: none;
	}

	.entry-item a:hover {
		text-decoration: underline;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		font-size: 0.8rem;
		opacity: 0.6;
	}

	.tag {
		opacity: 0.8;
	}
</style>
